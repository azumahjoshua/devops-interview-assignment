# Keycloak connection
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=acme

# Service client used for admin API access (seeded)
KEYCLOAK_CLIENT_ID=user-cleanup-service
KEYCLOAK_CLIENT_SECRET=cleanup-secret-change-me

# Cleanup policy
# Users inactive for this many days will be candidates for cleanup
INACTIVITY_DAYS=120

# Safety
# When true, log what would be deleted, don't actually delete
DRY_RUN=true

# Comma-separated usernames to never delete (in addition to service accounts)
EXCLUSIONS=admin,break-glass
